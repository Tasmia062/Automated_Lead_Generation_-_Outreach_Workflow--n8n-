    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst leadItems = $('Read Approved Leads').all();\nlet discountItems = [];\ntry {\n  discountItems = $('Create Discount Code').all();\n} catch (error) {\n  console.log('No discount codes created (optional vouchers)');\n}\nreturn inputItems.map((item, index) => {\n  const prepareData = item.json || {};\n  const leadData = leadItems[index]?.json || {};\n  const discountCode = discountItems[index]?.json?.discount_code?.code || '';\n  let emailBody = prepareData.emailBody ?? '';\n  if (typeof emailBody !== 'string') emailBody = String(emailBody);\n  emailBody = emailBody.replace(/\\r\\n/g, '\\n').replace(/\\r/g, '\\n');\n  const paragraphs = emailBody.split('\\n').map(line => line.trim()).filter(Boolean);\n  const htmlEmail = `<html><body style=\"font-family: Arial, sans-serif; line-height: 1.8; color: #333;\">${paragraphs.map(p => `<p style=\"margin:15px 0;\">${p}</p>`).join('')}</body></html>`;\n  return {\n    json: {\n      emailSubject: prepareData.emailSubject ?? '',\n      emailBody: htmlEmail,\n      recipientEmail: prepareData.recipientEmail ?? '',\n      recipientName: prepareData.recipientName ?? '',\n      Email: leadData.Email ?? '',\n      voucherCode: discountCode ? discountCode.toString().trim() : '',\n      dateSent: new Date().toISOString(),\n      rowNumber: leadData.row_number ?? null,\n      eventLink: prepareData.eventLink ?? leadData.eventLink ?? ''\n    }\n  };\n});"
      },
